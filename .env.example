# Environment variables template
# Copy to .env and fill in your values

# Database
DATABASE_PATH=tt_farm.db

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Automation Intervals (seconds)
CHECK_POSTS_INTERVAL=60
CHECK_WARM_INTERVAL=300

# Device Control
ADB_PATH=adb
SCRCPY_PATH=scrcpy

# AI Analysis (DeepSeek)
# Get API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
USE_AI_ANALYSIS=true

# Bot Behavior
# Options: casual, active, passive, aggressive
DEFAULT_BEHAVIOR_PROFILE=casual
MAX_DAILY_ACTIONS=500
SESSION_MAX_DURATION=3600

# Content Filtering
ENABLE_CONTENT_FILTERING=true
MIN_ENGAGEMENT_RATE=0.0
